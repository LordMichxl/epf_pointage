<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sn.epf.pointage.ui.ProfesseursController"
      spacing="0" style="-fx-background-color: #f5f5f5;">

    <!--EN-TÊTE -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: white; -fx-padding: 16 24 16 24;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 4, 0, 0, 2);">
        <Label text=" Gestion des Professeurs" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnAjouter" text="＋ Nouveau professeur"
                styleClass="btn-primary" onAction="#ouvrirFormulaire"/>
    </HBox>

    <!--BARRE DE RECHERCHE ET FILTRES -->
    <HBox spacing="12" style="-fx-padding: 16 24 12 24; -fx-background-color: #f5f5f5;">
        <TextField fx:id="champRecherche" promptText="  Rechercher par nom ou matricule..."
                   HBox.hgrow="ALWAYS"
                   style="-fx-pref-height: 36px; -fx-background-radius: 6px;
                          -fx-border-radius: 6px; -fx-border-color: #ddd;
                          -fx-padding: 0 12 0 12;"/>
        <ComboBox fx:id="filtreContrat" promptText="Type de contrat"
                  style="-fx-pref-height: 36px; -fx-pref-width: 160px;"/>
        <ComboBox fx:id="filtreFiliere" promptText="Filière"
                  style="-fx-pref-height: 36px; -fx-pref-width: 140px;"/>
        <Button text="Réinitialiser" styleClass="btn-secondary"
                onAction="#reinitialiserFiltres"
                style="-fx-pref-height: 36px;"/>
    </HBox>

    <!-- TABLEAU PRINCIPAL -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 0 24 24 24;">
        <TableView fx:id="tableProfesseurs" VBox.vgrow="ALWAYS"
                   style="-fx-background-radius: 8px; -fx-border-radius: 8px;
                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 1);">
            <columns>
                <TableColumn fx:id="colMatricule" text="Matricule" prefWidth="140"/>
                <TableColumn fx:id="colNom"       text="Nom"       prefWidth="130"/>
                <TableColumn fx:id="colPrenom"    text="Prénom"    prefWidth="130"/>
                <TableColumn fx:id="colEmail"     text="Email"     prefWidth="200"/>
                <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="120"/>
                <TableColumn fx:id="colContrat"   text="Contrat"   prefWidth="110"/>
                <TableColumn fx:id="colFiliere"   text="Filière"   prefWidth="100"/>
                <TableColumn fx:id="colStatut"    text="Statut"    prefWidth="90"/>
                <TableColumn fx:id="colActions"   text="Actions"   prefWidth="150"/>
            </columns>
            <placeholder>
                <Label text="Aucun professeur trouvé" style="-fx-text-fill: #999;"/>
            </placeholder>
        </TableView>

        <!-- Barre de statut -->
        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 8 4 0 4;">
            <Label fx:id="labelNbResultats" text="0 professeur(s)"
                   style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Double-clic pour modifier"
                   style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
        </HBox>
    </VBox>

</VBox>
